      "id": 10,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": "mysql",
          "rawSql": "SELECT\n  ROUND(COUNT(DISTINCT c.sha) / NULLIF(COUNT(DISTINCT c.author_id), 0) / GREATEST(DATEDIFF(NOW(), DATE_SUB(NOW(), INTERVAL $__interval_days DAY)), 1), 2) AS commit_freq\nFROM commits c\nWHERE c.authored_date >= DATE_SUB(NOW(), INTERVAL $__interval_days DAY)",
          "refId": "A",
          "format": "table"
        }
      ],
      "title": "Commit Frequency (commits/dev/day)",
      "type": "stat"
    },
    {
      "datasource": "mysql",
      "description": "Code churn: lines added + lines deleted as a percentage of total lines modified.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 40
              },
              {
                "color": "red",
                "value": 60
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 4
      },
      "id": 11,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": "mysql",
          "rawSql": "SELECT\n  ROUND(\n    SUM(cf_del.deletions)\n    / NULLIF(SUM(cf_add.additions), 0) * 100\n  , 1) AS churn_pct\nFROM commit_files cf_add\nJOIN commits c_add  ON c_add.sha  = cf_add.commit_sha\nJOIN commit_files cf_del ON cf_del.file_path = cf_add.file_path\nJOIN commits c_del  ON c_del.sha  = cf_del.commit_sha\nWHERE c_add.authored_date >= DATE_SUB(NOW(), INTERVAL $__interval_days DAY)\n  AND c_del.authored_date BETWEEN c_add.authored_date\n                               AND DATE_ADD(c_add.authored_date, INTERVAL 14 DAY)\n  AND c_del.sha    != c_add.sha\n  AND cf_del.deletions > 0",
          "refId": "A",
          "format": "table"
        }
      ],
      "title": "Code Churn %",
      "type": "stat"
    },
