    {
      "datasource": "mysql",
      "description": "Average commits per active contributor per day in the selected period.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }, { "color": "green", "value": 1 }] },
          "unit": "short",
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 4 },
      "id": 10,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": "mysql",
          "rawSql": "SELECT\n  ROUND(COUNT(DISTINCT c.sha) / NULLIF(COUNT(DISTINCT c.author_id), 0) / GREATEST(DATEDIFF(NOW(), DATE_SUB(NOW(), INTERVAL $__interval_days DAY)), 1), 2) AS commit_freq\nFROM commits c\nWHERE c.authored_date >= DATE_SUB(NOW(), INTERVAL $__interval_days DAY)",
          "refId": "A",
          "format": "table"
        }
      ],
      "title": "Commit Frequency (commits/dev/day)",
      "type": "stat"
    },

    {
      "datasource": "mysql",
      "description": "Code churn: lines added + lines deleted as a percentage of total lines modified.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 40 }, { "color": "red", "value": 60 }] },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 4 },
      "id": 11,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": "mysql",
          "rawSql": "SELECT\n  ROUND(\n    SUM(additions + deletions) / NULLIF(SUM(additions + deletions + GREATEST(additions - deletions, 0)), 0) * 100\n  , 1) AS churn_pct\nFROM pull_requests\nWHERE created_date >= DATE_SUB(NOW(), INTERVAL $__interval_days DAY)\n  AND status = 'MERGED'",
          "refId": "A",
          "format": "table"
        }
      ],
      "title": "Code Churn %",
      "type": "stat"
    },

    {
      "datasource": "mysql",
