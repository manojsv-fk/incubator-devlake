          "rawSql": "SELECT\n  ROUND(\n    SUM(CASE WHEN i.status = 'DONE' THEN 1 ELSE 0 END)\n    / NULLIF(COUNT(*), 0) * 100\n  , 1) AS say_do_ratio\nFROM issues i\nJOIN sprint_issues si ON si.issue_id = i.id\nJOIN sprints s        ON s.id = si.sprint_id\nWHERE s.completed_date >= DATE_SUB(NOW(), INTERVAL $__interval_days DAY)\n  AND s.status = 'CLOSED'",
          "refId": "A",
          "format": "table"
        }
