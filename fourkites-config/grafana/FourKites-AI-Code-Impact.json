      "options": { "cellHeight": "sm", "footer": { "countRows": false, "enablePagination": false, "fields": "", "reducer": ["sum"], "show": false }, "showHeader": true },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": "mysql",
          "rawSql": "SELECT\n  repo_id,\n  SUM(ai_lines_added) AS ai_lines,\n  SUM(total_lines_added) AS total_lines,\n  ROUND(SUM(ai_lines_added) / NULLIF(SUM(total_lines_added), 0) * 100, 1) AS ai_code_ratio\nFROM _tool_aicode_daily_aggregates\nWHERE\n  date >= DATE_SUB(NOW(), INTERVAL $__interval_days DAY)\n  AND connection_id = $connection_id\nGROUP BY repo_id\nORDER BY ai_code_ratio DESC",
          "refId": "A",
          "format": "table"
