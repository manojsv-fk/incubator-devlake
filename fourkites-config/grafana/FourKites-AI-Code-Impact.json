          "datasource": "mysql",
          "rawSql": "SELECT\n  date AS time,\n  ROUND(AVG(ai_code_ratio), 2) AS 'AI Code Ratio %'\nFROM _tool_aicode_daily_aggregates\nWHERE\n  $__timeFilter(date)\n  AND connection_id = $connection_id\nGROUP BY date\nORDER BY date ASC",
