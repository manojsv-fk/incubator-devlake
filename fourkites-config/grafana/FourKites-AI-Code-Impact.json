    {
      "datasource": "mysql",
      "description": "Percentage of all new lines added that were AI-generated (Copilot or Claude), averaged across all repos, for the selected period.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 20 },
              { "color": "yellow", "value": 40 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 3 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": "mysql",
          "rawSql": "SELECT\n  ROUND(AVG(ai_code_ratio), 1) AS ai_code_ratio\nFROM _tool_aicode_daily_aggregates\nWHERE\n  date >= DATE_SUB(NOW(), INTERVAL $__interval_days DAY)\n  AND connection_id = $connection_id",
          "refId": "A",
          "format": "table"
        }
      ],
      "title": "AI Code Ratio (avg across all repos)",
      "type": "stat"
    },

