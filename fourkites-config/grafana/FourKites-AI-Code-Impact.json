      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "id": 8,
      "options": { "displayLabels": ["percent"], "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "values": ["value", "percent"] }, "pieType": "donut", "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [
        {
          "datasource": "mysql",
          "rawSql": "SELECT\n  CASE\n    WHEN ai_tool = 'copilot' THEN 'GitHub Copilot'\n    WHEN ai_tool = 'claude' THEN 'Claude / Claude Code'\n    WHEN ai_tool = 'other_ai' THEN 'Other AI'\n    ELSE 'Human'\n  END AS tool,\n  COUNT(*) AS commits\nFROM _tool_aicode_commit_metrics\nWHERE\n  authored_at >= DATE_SUB(NOW(), INTERVAL $__interval_days DAY)\n  AND connection_id = $connection_id\nGROUP BY ai_tool\nORDER BY commits DESC",
          "refId": "A",
          "format": "table"
        }
      ],
      "title": "AI Commits by Tool",
      "type": "piechart"
    },

